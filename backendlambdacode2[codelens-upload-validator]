EXTENSION_PRIORITY = {
    # Tier 1 — Core source code (highest priority)
    '.py': 1, '.js': 1, '.ts': 1, '.tsx': 1, '.jsx': 1,
    '.go': 1, '.rs': 1, '.java': 1, '.kt': 1, '.swift': 1,
    '.c': 1, '.cpp': 1, '.cs': 1, '.rb': 1, '.php': 1,
