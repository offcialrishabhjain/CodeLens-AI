# CHAT HANDLER — unchanged from original
# ─────────────────────────────────────────────────────────────────
def handle_chat(event):
    try:
        user_query   = event.get('user_query', '').strip()
        file_name    = event.get('file_name', '').strip()
        chat_history = event.get('chat_history', [])

        if not user_query:
            return {'statusCode': 400, 'body': json.dumps({'error': 'Empty query.'})}

        code_context     = ""
        analysis_summary = ""
        if file_name:
            try:
                db_resp          = table.get_item(Key={'fileName': file_name})
                item             = db_resp.get('Item', {})
                code_context     = item.get('codeContext', '')[:8000]
                analysis_summary = item.get('analysis', '')[:3000]
            except Exception as fetch_err:
                print(f"DynamoDB fetch error: {fetch_err}")

        system_context = f"""You are CodeLens AI — a helpful, concise code assistant.
The user has uploaded a project. Use the code and analysis below to answer their questions accurately.
If the answer isn't in the provided context, say so honestly.

--- CODE CONTEXT (truncated) ---
{code_context if code_context else "Not available. Answer based on general knowledge."}

--- PRIOR ANALYSIS SUMMARY ---
{analysis_summary if analysis_summary else "Not available."}

RULES:
- Be concise and developer-friendly.
- Use plain text. No markdown symbols like # or *.
- If referencing a specific file or function, name it explicitly.
- Max 200 words per reply.
"""

        messages = []
        for turn in chat_history:
            role    = turn.get('role', 'user')
            content = turn.get('content', '')
            if role in ('user', 'assistant') and content:
                messages.append({"role": role, "content": [{"text": content}]})

        messages.append({
            "role": "user",
            "content": [{"text": f"{system_context}\n\nUser question: {user_query}"}]
        })

        body = json.dumps({
            "messages": messages,
            "inferenceConfig": {
                "max_new_tokens": 512,
                "temperature": 0.3
            }
        })

        ai_response = invoke_bedrock(body)
        reply = json.loads(ai_response.get('body').read())['output']['message']['content'][0]['text']

        return {
            'statusCode': 200,
            'body': json.dumps({'chat_answer': reply.strip()})
        }

    except Exception as e:
        print(f"CHAT_ERROR: {str(e)}")
        return {
            'statusCode': 500,
            'body': json.dumps({'chat_answer': f'Error processing your question: {str(e)}'})
        }
