"""

        # 5. CALL AMAZON NOVA
        body = json.dumps({
            "messages": [{"role": "user", "content": [{"text": prompt_text}]}],
            "inferenceConfig": {
                "max_new_tokens": 6144,
                "temperature": 0.1
            }
        })
        ai_response = invoke_bedrock(body)
        result_text = json.loads(ai_response.get('body').read())['output']['message']['content'][0]['text']

        # 6. SAVE TO DYNAMODB
        table.put_item(Item={
            'fileName':    key,
            'analysis':    result_text,
            'codeContext': code_context,
            'truncated':   was_truncated,
            'timestamp':   str(datetime.datetime.now())
        })

        return {'statusCode': 200, 'body': json.dumps({'analysis': result_text})}

    except Exception as e:
        print(f"CRITICAL_ERROR: {str(e)}")
        return {'statusCode': 500, 'body': json.dumps({'error': str(e)})}


