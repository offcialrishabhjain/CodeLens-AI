    # Tier 3 — Markup and docs (lowest priority)
    '.html': 3, '.css': 3, '.md': 3, '.txt': 3, '.xml': 3,
}

def _get_priority(filename):
    """Return sort priority for a file. Lower = higher priority."""
    ext = '.' + filename.rsplit('.', 1)[-1].lower() if '.' in filename else ''
    return EXTENSION_PRIORITY.get(ext, 2)  # unknown extensions get tier 2


# ── BEDROCK RESILIENCE ──
# Nova Lite requires the regional inference profile prefix in ap-south-1
# Nova Micro uses the apac cross-region prefix as before
BEDROCK_MODELS = [
    ('apac.amazon.nova-lite-v1:0',        bedrock),           # primary  — Nova Lite, apac cross-region profile
    ('us-east-1.amazon.nova-lite-v1:0',   bedrock_fallback),  # fallback — Nova Lite, us-east-1 profile
    ('apac.amazon.nova-micro-v1:0',       bedrock),           # last resort — Nova Micro if Lite throttled
]
BEDROCK_RETRIES      = 3
BEDROCK_INITIAL_WAIT = 1
BEDROCK_MAX_WAIT     = 8


def invoke_bedrock(body):
    """
    Call Bedrock with exponential back-off retry across BEDROCK_MODELS.
    Tries each model up to BEDROCK_RETRIES times before falling back to the next.
    Third entry uses a cross-region client (us-east-1) to escape regional throttles.
    Uses botocore.ClientError for client-agnostic exception handling — safe across
    all regional client instances regardless of which boto3 client raised the error.
    Raises the last exception if all models and retries are exhausted.
    """
    last_exc = None
    for model_id, client in BEDROCK_MODELS:
        wait = BEDROCK_INITIAL_WAIT
        for attempt in range(BEDROCK_RETRIES):
            try:
                response = client.invoke_model(
                    modelId=model_id,
                    body=body,
                    contentType="application/json"
                )
                if attempt > 0 or (model_id, client) != BEDROCK_MODELS[0]:
                    print(f"BEDROCK_SUCCESS: model={model_id}, attempt={attempt+1}")
                return response
            except ClientError as e:
                error_code = e.response['Error']['Code']
                last_exc = e
                if error_code == 'ThrottlingException':
                    if attempt < BEDROCK_RETRIES - 1:
                        print(f"BEDROCK_THROTTLE: model={model_id}, attempt={attempt+1}, waiting {wait}s")
                        time.sleep(wait)
                        wait = min(wait * 2, BEDROCK_MAX_WAIT)
                elif error_code in ('ModelErrorException', 'InternalServerException', 'ServiceUnavailableException'):
                    print(f"BEDROCK_MODEL_ERROR: model={model_id}, attempt={attempt+1}, err={str(e)}")
                    break
                else:
                    print(f"BEDROCK_UNEXPECTED_ERROR: model={model_id}, code={error_code}, err={str(e)}")
                    raise
        print(f"BEDROCK_FALLBACK: exhausted retries for {model_id}, trying next model.")
    raise last_exc


def lambda_handler(event, context):

    # ─────────────────────────────────────────────
    # ROUTE 1: DOUBTS CHAT (invoked directly from frontend)
    # ─────────────────────────────────────────────
    if 'user_query' in event:
        return handle_chat(event)

    # ─────────────────────────────────────────────
    # ROUTE 2: S3 TRIGGER (full codebase analysis)
    # ─────────────────────────────────────────────
    try:
        time.sleep(2)

        # 1. Get S3 Event Details
        bucket  = event['Records'][0]['s3']['bucket']['name']
        raw_key = event['Records'][0]['s3']['object']['key']
        key     = urllib.parse.unquote_plus(raw_key)

        # 2. FILE DISCOVERY & METADATA EXTRACTION
        try:
            response   = s3.get_object(Bucket=bucket, Key=key)
            user_level = response.get('Metadata', {}).get('user-level', 'Intermediate')
        except s3.exceptions.NoSuchKey:
            objs        = s3.list_objects_v2(Bucket=bucket, MaxKeys=5)
            sorted_objs = sorted(objs.get('Contents', []), key=lambda x: x['LastModified'], reverse=True)
            if not sorted_objs:
                raise Exception("Bucket is empty.")
            key        = sorted_objs[0]['Key']
            response   = s3.get_object(Bucket=bucket, Key=key)
            user_level = response.get('Metadata', {}).get('user-level', 'Intermediate')

        # 3. ZIP PROCESSING
        zip_data     = response['Body'].read()
        raw_snippets = []  # list of (priority, text) tuples for sorting

        with zipfile.ZipFile(io.BytesIO(zip_data)) as z:
            for info in z.infolist():
                if info.is_dir() or info.filename.startswith('__MACOSX'):
                    continue

                fname_lower = info.filename.lower()
                fname_base  = fname_lower.split('/')[-1]  # just the filename, no path

                # ── FIX #3: Trimmed blocklist — only skip genuinely junk folders ──
                path_parts = set(fname_lower.replace('\\', '/').split('/'))
                if path_parts & SKIP_FOLDERS:
                    continue

                # Skip binary and generated file extensions
                # Handle compound extensions like .min.js
                skip = False
                for ext in SKIP_EXTENSIONS:
                    if fname_lower.endswith(ext):
                        skip = True
                        break
                if skip:
                    continue

                # Determine read limit for this file
                # ── FIX #5: JSON whitelist + raised caps ──
                if fname_base in JSON_WHITELIST:
                    # Critical config files get full source-level read
                    limit = SOURCE_FILE_CAP
                elif any(fname_lower.endswith(ext) for ext in ('.json', '.toml', '.yaml', '.yml', '.cfg', '.ini', '.conf', '.env')):
                    # All other JSON/config gets raised cap (was 1000, now 3000)
                    limit = JSON_DEFAULT_CAP
                elif any(fname_lower.endswith(ext) for ext in LOW_VALUE_EXTENSIONS):
                    # Markup, docs, plain text — still low cap
                    limit = LOW_VALUE_CAP
                else:
                    # ── FIX #2: Source files get 15,000 bytes (was 5,000) ──
                    limit = SOURCE_FILE_CAP

                with z.open(info.filename) as f:
                    snippet = f.read(limit).decode('utf-8', errors='ignore')

                priority = _get_priority(fname_lower)
                raw_snippets.append((priority, f"FILE: {info.filename}\nCODE:\n{snippet}\n---"))

        # ── FIX #4A companion: Sort by priority before building context ──
        # Ensures source code files fill the context window before configs
        # and markup, so the AI sees the most important files even when truncated
        raw_snippets.sort(key=lambda x: x[0])
        # ── FIX B — Cap at top 50 files after priority sort ──
        # Prevents context explosion on large repos. The priority sort above
        # guarantees the best 50 files are kept, not just the first 50 alphabetically.
        raw_snippets = raw_snippets[:50]
        file_details = [text for _, text in raw_snippets]

        raw_context   = "\n".join(file_details)
        was_truncated = len(raw_context) > MAX_CODE_CONTEXT
        code_context  = raw_context[:MAX_CODE_CONTEXT]

        truncation_notice = ""
        if was_truncated:
            total_files   = len(file_details)
            chars_dropped = len(raw_context) - MAX_CODE_CONTEXT
            truncation_notice = (
                f"\n\n[NOTICE: Codebase was large. {chars_dropped:,} characters across {total_files} files "
                f"were truncated. Analysis reflects the first {MAX_CODE_CONTEXT:,} characters only. "
                f"Files were prioritised by type: source code first, then config, then markup.]\n"
            )
            print(f"TRUNCATION_WARNING: key={key}, total_chars={len(raw_context)}, files={total_files}")

        # 4. ANALYSIS PROMPT (unchanged — all original sections preserved)
        prompt_text = f"""
